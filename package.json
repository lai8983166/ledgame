{
  "name": "led-game",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Vue 3 + Vite + Electron starter",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k \"pnpm run dev:renderer\" \"pnpm run dev:electron\"",
    "dev:renderer": "vite --host 127.0.0.1",
    "dev:electron": "wait-on tcp:127.0.0.1:5174 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5174 electron .",
    "build": "vite build",
    "test": "node --test tests/*.test.mjs",
    "portable:prepare": "node scripts/prepare-portable-resources.cjs",
    "portable:dir": "pnpm run portable:prepare && pnpm run build && electron-builder --config electron-builder.json --win dir",
    "portable:zip": "pnpm run portable:prepare && pnpm run build && electron-builder --config electron-builder.json --win zip",
    "portable:dist": "pnpm run portable:prepare && pnpm run build && electron-builder --config electron-builder.json --win dir zip",
    "preview": "vite preview --host 127.0.0.1",
    "start": "electron ."
  },
  "dependencies": {
    "gifenc": "1.0.3",
    "vue": "^3.5.13",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.1",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^34.0.0",
    "electron-builder": "^26.15.3",
    "vite": "^6.0.7",
    "wait-on": "^8.0.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ]
  }
}
